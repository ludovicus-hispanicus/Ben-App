{
  "version": "1.0",
  "description": "Akkadian OCR post-processing rules for fixing common errors",

  "invalid_sequences": {
    "description": "Sequences that are impossible in Akkadian - will be replaced",
    "rules": [
      {
        "pattern": "qš",
        "replacement": "aš",
        "description": "q before š is impossible, likely a→q confusion"
      },
      {
        "pattern": "qṣ",
        "replacement": "aṣ",
        "description": "q before ṣ is impossible"
      },
      {
        "pattern": "qṭ",
        "replacement": "aṭ",
        "description": "q before ṭ is impossible"
      },
      {
        "pattern": "qq",
        "replacement": "aq",
        "description": "Double q is impossible in Akkadian"
      },
      {
        "pattern": "nnu",
        "replacement": "mu",
        "description": "nnu is likely misread mu"
      },
      {
        "pattern": "nii",
        "replacement": "mi",
        "description": "nii is likely misread mi"
      },
      {
        "pattern": "qr",
        "replacement": "ar",
        "description": "qr before r is impossible"
      },
      {
        "pattern": "DI5",
        "replacement": "DIŠ",
        "description": "DI5 is misread DIŠ"
      }, {
        "pattern": "unu",
        "replacement": "um",
        "description": "unu is misread um"
      }
      
    ]
  },

  "case_normalization": {
    "description": "Fix incorrect capitalization - capitals should not appear mid-word",
    "enabled": true,
    "rules": [
      {
        "type": "lowercase_after_lowercase",
        "description": "Convert capital to lowercase when preceded by lowercase letter (e.g., aŠum → ašum)"
      }
    ]
  },

  "character_confusions": {
    "description": "Common OCR character confusions with context",
    "rules": [
      {
        "confused": "q",
        "likely": "a",
        "context": "before_sibilant",
        "description": "q is often misread a before sibilants (š, ṣ, s, z)"
      },
      {
        "confused": "l",
        "likely": "i",
        "context": "word_final",
        "description": "Final l might be misread i in certain contexts"
      }
    ]
  },

  "impossible_initials": {
    "description": "Characters that cannot appear word-initially",
    "characters": []
  },

  "impossible_finals": {
    "description": "Characters that cannot appear word-finally",
    "characters": []
  },

  "sign_specific": {
    "description": "Corrections for specific sign readings",
    "rules": []
  },

  "vowel_patterns": {
    "description": "Invalid vowel sequences",
    "rules": []
  },

  "custom_replacements": {
    "description": "User-defined direct replacements (applied after case normalization)",
    "rules": [
      {
        "pattern": "dis",
        "replacement": "DIŠ",
        "description": "dis is misread DIŠ (Sumerian numeral 1)"
      }
    ]
  },

  "settings": {
    "case_sensitive": false,
    "apply_to_determinatives": false,
    "log_corrections": true
  }
}
